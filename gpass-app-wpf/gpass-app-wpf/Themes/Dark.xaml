<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Színek -->
    <SolidColorBrush x:Key="AppBackground"       Color="#0F1117"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#1A1A2E"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush"  Color="#2D2D4E"/>
    <SolidColorBrush x:Key="PrimaryText"         Color="#E8EEFF"/>
    <SolidColorBrush x:Key="SecondaryText"       Color="#B0BAD0"/>
    <SolidColorBrush x:Key="MutedText"           Color="#6B7A99"/>
    <SolidColorBrush x:Key="Accent"              Color="#4F9CF9"/>
    <SolidColorBrush x:Key="AccentHover"         Color="#3B82F6"/>
    <SolidColorBrush x:Key="InputBackground"     Color="#16213E"/>
    <SolidColorBrush x:Key="InputBorder"         Color="#2D3A5E"/>
    <SolidColorBrush x:Key="ToolbarBackground"   Color="#141428"/>
    <SolidColorBrush x:Key="AlternatingRow"      Color="#141428"/>
    <SolidColorBrush x:Key="TabBackground"       Color="#1A1A2E"/>
    <SolidColorBrush x:Key="ToggleBtnBg"         Color="#2D2D4E"/>
    <SolidColorBrush x:Key="ToggleBtnFg"         Color="#E8EEFF"/>
    <SolidColorBrush x:Key="LoginOuterBg"        Color="#0F1117"/>
    <SolidColorBrush x:Key="LoginCardBg"         Color="#1A1A2E"/>
    <SolidColorBrush x:Key="LoginCardBorder"     Color="#2D2D4E"/>
    <SolidColorBrush x:Key="WindowBackground"    Color="#0F1117"/>

    


    <!-- DataGrid kijelölés színei - felülírják a WPF SystemColor brush-ait -->
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"         Color="#4F9CF9"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"     Color="White"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#4F9CF9"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"           Color="Transparent"/>

</ResourceDictionary>
