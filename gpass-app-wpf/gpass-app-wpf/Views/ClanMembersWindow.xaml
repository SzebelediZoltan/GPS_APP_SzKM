<Window x:Class="gpass_app_wpf.Views.ClanMembersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="680"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}">

    <DockPanel Margin="16">


        <!-- FEJLÉC -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="{Binding Title}"
                       FontSize="17"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"/>

            <TextBlock Text="{Binding ClanInfo}"
                       FontSize="12"
                       Foreground="{DynamicResource MutedText}"
                       Margin="0,3,0,0"/>

            <TextBlock Text="⏳ Betöltés..."
                       FontStyle="Italic"
                       Foreground="{DynamicResource MutedText}"
                       Margin="0,4,0,0"
                       Visibility="{Binding Loading, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>


        <!-- HIBASÁV -->
        <Border DockPanel.Dock="Top"
                Background="#3D1515"
                BorderBrush="#C53030"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,7"
                Margin="0,0,0,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠ " Foreground="#FC8181" FontWeight="Bold" Margin="0,1,6,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="#FC8181"
                           FontSize="12" TextWrapping="Wrap"/>
                <Button Grid.Column="2" Content="✕" Width="22" Height="22"
                        Background="Transparent" Foreground="#FC8181" BorderThickness="0"
                        Command="{Binding DismissErrorCommand}" VerticalAlignment="Top"/>
            </Grid>
        </Border>


        <!-- KLÁN ADATOK -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="5"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,0,0,10">

            <StackPanel>

                <TextBlock Text="Klán adatok"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}"
                           Margin="0,0,0,10"/>


                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>


                    <!-- KLÁN NÉV -->
                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Klán neve *"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>

                        <TextBox Text="{Binding ClanName, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding NameSaving, Converter={StaticResource InverseBool}}"/>

                        <TextBlock Text="{Binding ClanNameError}"
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="11"
                                   Margin="2,3,0,0"
                                   Visibility="{Binding HasClanNameError, Converter={StaticResource BoolToVisibility}}"/>

                    </StackPanel>


                    <!-- LEÍRÁS -->
                    <StackPanel Grid.Column="2">

                        <TextBlock Text="Leírás (opcionális)"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>

                        <TextBox MaxLength="200"
                                 Text="{Binding ClanDescription, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding NameSaving, Converter={StaticResource InverseBool}}"/>

                        <TextBlock Text="{Binding ClanDescriptionError}"
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="11"
                                   Margin="2,3,0,0"
                                   Visibility="{Binding HasClanDescriptionError, Converter={StaticResource BoolToVisibility}}"/>

                    </StackPanel>

                </Grid>


                <!-- MENTÉS -->
                <Grid Margin="0,10,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding HasNameSaveResult, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding NameSaveResult}" FontSize="12" Margin="2,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NameSaveIsError}" Value="True">
                                            <Setter Property="Foreground" Value="#FC8181"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Padding="14,6"
                            Background="{DynamicResource Accent}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Command="{Binding SaveNameCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏳ "
                                       Visibility="{Binding NameSaving, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="Mentés"/>
                        </StackPanel>

                    </Button>

                </Grid>

            </StackPanel>

        </Border>


        <!-- TAG HOZZÁADÁSA -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="5"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,0,0,10">

            <StackPanel>

                <TextBlock Text="Tag hozzáadása"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}"
                           Margin="0,0,0,10"/>


                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Margin="0,0,8,0"
                             Text="{Binding AddSearch, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Keresés felhasználónév vagy email alapján"/>

                    <TextBlock Grid.Column="1"
                               Text="⏳"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource MutedText}"
                               Visibility="{Binding AddSearching, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Grid.Column="2"
                            Content="＋  Hozzáadás"
                            Padding="12,5"
                            Background="{DynamicResource Accent}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Command="{Binding AddMemberCommand}"/>

                </Grid>


                <!-- TALÁLATI LISTA -->
                <ListBox x:Name="addSearchListBox"
                         ItemsSource="{Binding AddSearchResults}"
                         MaxHeight="90"
                         Margin="0,6,0,0"
                         BorderBrush="{DynamicResource SurfaceBorderBrush}"
                         BorderThickness="1"
                         SelectionChanged="AddSearchListBox_SelectionChanged"
                         Visibility="{Binding AddSearchResults.Count, Converter={StaticResource IntToVisibility}}">

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <StackPanel Orientation="Horizontal" Margin="2,3">

                                <TextBlock Text="{Binding username}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryText}"/>

                                <TextBlock Text="  "/>

                                <TextBlock Text="{Binding email}"
                                           Foreground="{DynamicResource MutedText}"
                                           FontSize="11"/>

                            </StackPanel>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>


                <!-- KIVÁLASZTOTT USER -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource Accent}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="8,5"
                        Margin="0,6,0,0"
                        Visibility="{Binding HasUserToAdd, Converter={StaticResource BoolToVisibility}}">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="✔ Kiválasztva: "
                                   Foreground="{DynamicResource Accent}"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding UserToAddText}"
                                   Foreground="{DynamicResource PrimaryText}"/>

                    </StackPanel>

                </Border>

            </StackPanel>

        </Border>


        <!-- TOOLBAR -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource ToolbarBackground}"
                Padding="10,7"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryText}"
                           Text="{Binding Members.Count, StringFormat='Összesen: {0} tag'}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">

                    <Button Content="👑  Vezető kinevezése"
                            Padding="10,5"
                            Margin="0,0,8,0"
                            Background="#e67e22"
                            Foreground="White"
                            Command="{Binding ChangeLeaderCommand}"/>

                    <Button Content="✕  Tag eltávolítása"
                            Padding="10,5"
                            Background="#e74c3c"
                            Foreground="White"
                            Command="{Binding RemoveMemberCommand}"/>

                </StackPanel>

            </Grid>

        </Border>


        <!-- TAGOK TÁBLÁZAT -->
        <DataGrid ItemsSource="{Binding Members}"
                  SelectedItem="{Binding SelectedMember, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  BorderBrush="{DynamicResource SurfaceBorderBrush}"
                  BorderThickness="1">

            <DataGrid.RowStyle>

                <Style TargetType="DataGridRow">

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding is_leader}" Value="True">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>

                    </Style.Triggers>

                </Style>

            </DataGrid.RowStyle>


            <DataGrid.Columns>

                <DataGridTextColumn Header="User ID"
                                    Binding="{Binding user_id}"
                                    Width="70"/>

                <DataGridTextColumn Header="Felhasználó"
                                    Binding="{Binding display_name}"
                                    Width="150"/>

                <DataGridTextColumn Header="Email"
                                    Binding="{Binding display_email}"
                                    Width="*"/>

                <DataGridTextColumn Header="Szerep"
                                    Binding="{Binding role_label}"
                                    Width="80"/>

                <DataGridTextColumn Header="Csatlakozott"
                                    Binding="{Binding joined_at, Converter={StaticResource IsoDate}}"
                                    Width="135"/>

            </DataGrid.Columns>

        </DataGrid>


    </DockPanel>
</Window>