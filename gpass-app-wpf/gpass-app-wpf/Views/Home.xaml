<Window x:Class="gpass_app_wpf.Views.Home"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GPass Admin" Height="620" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}">

    <DockPanel Margin="16">

        <!-- Fejléc -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="20" Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock Text="GPASS" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                    <TextBlock Text=" Admin" FontSize="14" Foreground="{DynamicResource MutedText}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Üdvözlés -->
                <TextBlock Grid.Column="1" FontSize="13"
                           Foreground="{DynamicResource MutedText}"
                           Text="{Binding WelcomeText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Jobb oldal: téma + kijelentkezés -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="themeToggleBtn" Content="🌙" FontSize="15"
                            Width="34" Height="34" Padding="0" Margin="0,0,8,0"
                            Background="{DynamicResource ToggleBtnBg}"
                            Foreground="{DynamicResource ToggleBtnFg}"
                            BorderThickness="1" BorderBrush="{DynamicResource SurfaceBorderBrush}"
                            Click="ThemeToggle_Click"
                            ToolTip="Téma váltása"/>
                    <Button Content="Kijelentkezés" Padding="12,6"
                            Background="{DynamicResource ToolbarBackground}"
                            Foreground="{DynamicResource PrimaryText}"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="1"
                            Command="{Binding LogoutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl>

            <!-- ── FELHASZNÁLÓK TAB ── -->
            <TabItem Header="👥 Felhasználók">
                <DockPanel>
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackground}" CornerRadius="4"
                            Padding="10,8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button Content="+  Létrehozás" Padding="12,6" Margin="0,0,8,0"
                                        Background="#27ae60" Foreground="White"
                                        Command="{Binding AddUserCommand}"/>
                                <Button Content="✎  Szerkesztés" Padding="12,6" Margin="0,0,8,0"
                                        Background="#2980b9" Foreground="White"
                                        Command="{Binding EditUserCommand}"/>
                                <Button Content="🔍  Részletek" Padding="12,6" Margin="0,0,8,0"
                                        Background="#8e44ad" Foreground="White"
                                        Command="{Binding ViewDetailCommand}"/>
                                <Button Content="✕  Törlés" Padding="12,6"
                                        Background="#e74c3c" Foreground="White"
                                        Command="{Binding DeleteUserCommand}"/>
                            </StackPanel>

                            <!-- Keresősáv -->
                            <Border Grid.Column="1" HorizontalAlignment="Right"
                                    Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                    CornerRadius="4" Padding="8,0" Width="230">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" Foreground="{DynamicResource MutedText}" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox Text="{Binding UserSearch, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="{DynamicResource PrimaryText}"
                                             VerticalAlignment="Center" Width="185" Padding="0,5"
                                             ToolTip="Keresés felhasználónév vagy email alapján"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Border>

                    <!-- Hibasáv -->
                    <Border DockPanel.Dock="Top"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                            Background="#3D1515" BorderBrush="#C53030" BorderThickness="1"
                            CornerRadius="4" Padding="10,7" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⚠ " Foreground="#FC8181"
                                       FontWeight="Bold" Margin="0,1,6,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}"
                                       Foreground="#FC8181" FontSize="13" TextWrapping="Wrap"/>
                            <Button Grid.Column="2" Content="✕" Width="24" Height="24"
                                    Background="Transparent" Foreground="#FC8181" BorderThickness="0"
                                    Command="{Binding DismissErrorCommand}" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <DataGrid ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserAddRows="False"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"             Binding="{Binding ID}"       Width="55"/>
                            <DataGridTextColumn Header="Felhasználónév" Binding="{Binding username}" Width="200"/>
                            <DataGridTextColumn Header="Email"          Binding="{Binding email}"    Width="*"/>
                            <DataGridCheckBoxColumn Header="Admin"      Binding="{Binding isAdmin}"  Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── KLÁNOK TAB ── -->
            <TabItem Header="🛡 Klánok">
                <DockPanel DataContext="{Binding ClanVM}">
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackground}" CornerRadius="4"
                            Padding="10,8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button Content="+  Létrehozás" Padding="12,6" Margin="0,0,8,0"
                                        Background="#27ae60" Foreground="White"
                                        Command="{Binding CreateClanCommand}"/>
                                <Button Content="✎  Szerkesztés" Padding="12,6" Margin="0,0,8,0"
                                        Background="#2980b9" Foreground="White"
                                        Command="{Binding ViewMembersCommand}"/>
                                <Button Content="✕  Törlés" Padding="12,6"
                                        Background="#e74c3c" Foreground="White"
                                        Command="{Binding DeleteClanCommand}"/>
                            </StackPanel>

                            <!-- Keresősáv -->
                            <Border Grid.Column="1" HorizontalAlignment="Right"
                                    Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                    CornerRadius="4" Padding="8,0" Width="230">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" Foreground="{DynamicResource MutedText}" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox Text="{Binding ClanSearch, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="{DynamicResource PrimaryText}"
                                             VerticalAlignment="Center" Width="185" Padding="0,5"
                                             ToolTip="Keresés klán neve alapján"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Border>

                    <!-- Hibasáv -->
                    <Border DockPanel.Dock="Top"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                            Background="#3D1515" BorderBrush="#C53030" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ErrorMessage}"
                                       Foreground="#FC8181" FontSize="13" TextWrapping="Wrap"/>
                            <Button Grid.Column="1" Content="✕" Width="24" Height="24"
                                    Background="Transparent" Foreground="#FC8181" BorderThickness="0"
                                    Command="{Binding DismissErrorCommand}" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <DataGrid ItemsSource="{Binding Clans}"
                              SelectedItem="{Binding SelectedClan, Mode=TwoWay}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserAddRows="False"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              AlternatingRowBackground="{DynamicResource AlternatingRow}" BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"          Binding="{Binding id}"           Width="50"/>
                            <DataGridTextColumn Header="Klán neve"   Binding="{Binding name}"         Width="170"/>
                            <DataGridTextColumn Header="Vezető"      Binding="{Binding leader_name}"  Width="120"/>
                            <DataGridTextColumn Header="Tagok"       Binding="{Binding total_members}" Width="60"/>
                            <DataGridTextColumn Header="Leírás"      Binding="{Binding description}"  Width="150"/>
                            <DataGridTextColumn Header="Létrehozva"  Binding="{Binding created_at, Converter={StaticResource IsoDate}}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
