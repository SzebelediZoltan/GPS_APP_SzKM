<Window x:Class="gpass_app_wpf.Views.UserDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:gpass_app_wpf.ViewModels"
        Title="{Binding Title}"
        Height="580"
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}">

    <DockPanel Margin="16" Background="{DynamicResource SurfaceBrush}">

        <!-- FEJLÉC -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">

            <TextBlock Text="{Binding Title}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"/>

            <TextBlock Text="{Binding UserInfo}"
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryText}"
                       Margin="0,3,0,0"/>

            <TextBlock Text="⏳ Betöltés..."
                       FontStyle="Italic"
                       Foreground="{DynamicResource MutedText}"
                       Margin="0,4,0,0"
                       Visibility="{Binding Loading, Converter={StaticResource BoolToVisibility}}"/>

        </StackPanel>


        <!-- HIBAÜZENET -->
        <Border DockPanel.Dock="Top"
                Background="#3D1515"
                BorderBrush="#C53030"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,7"
                Margin="0,0,0,8"
                Visibility="{Binding HasErrors, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠ " Foreground="#FC8181" FontWeight="Bold" Margin="0,1,6,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Errors}" Foreground="#FC8181"
                           FontSize="12" TextWrapping="Wrap"/>
                <Button Grid.Column="2" Content="✕" Width="22" Height="22"
                        Background="Transparent" Foreground="#FC8181" BorderThickness="0"
                        Command="{Binding DismissErrorsCommand}" VerticalAlignment="Top"/>
            </Grid>
        </Border>


        <TabControl>

            


            <!-- MARKEREK -->
            <TabItem Header="📍 Markerek">

                <DockPanel>

                    <Border DockPanel.Dock="Bottom"
                            Background="{DynamicResource ToolbarBackground}"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="10,8">

                        <StackPanel>

                            <Grid Visibility="{Binding HasSelectedMarker, Converter={StaticResource BoolToVisibility}}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Típus:"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryText}"
                                           Margin="0,0,6,0"/>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Source={x:Static vm:UserDetailViewModel.AllowedMarkerTypes}}"
                                          SelectedItem="{Binding EditMarkerType}"/>


                                <TextBlock Grid.Column="3"
                                           Text="Pont:"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryText}"
                                           Margin="0,0,6,0"/>

                                <TextBox Grid.Column="4"
                                         Text="{Binding EditMarkerScore, UpdateSourceTrigger=PropertyChanged}"/>


                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding MarkerEditError}"
                                               FontSize="11" Margin="10,0,0,0"
                                               Foreground="#FC8181"
                                               Visibility="{Binding HasMarkerEditError, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="{Binding MarkerEditResult}"
                                               FontSize="11" Margin="10,0,0,0"
                                               Foreground="{DynamicResource Accent}"
                                               Visibility="{Binding HasMarkerEditResult, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>


                                <Button Grid.Column="6"
                                        Padding="12,5"
                                        Background="{DynamicResource Accent}"
                                        Foreground="White"
                                        Command="{Binding EditMarkerCommand}">

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏳ "
                                                   Visibility="{Binding MarkerSaving, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock Text="✎  Mentés"/>
                                    </StackPanel>

                                </Button>

                                <Button Grid.Column="8"
                                        Padding="12,5"
                                        Background="{DynamicResource Accent}"
                                        Foreground="White"
                                        Command="{Binding DeleteMarkerCommand}">

                                    <TextBlock Text="✕  Törlés"/>

                                </Button>

                            </Grid>


                            <TextBlock Text="Jelölj ki egy markert a szerkesztéshez vagy törléshez."
                                       Foreground="{DynamicResource MutedText}"
                                       FontStyle="Italic"
                                       FontSize="12"
                                       Visibility="{Binding HasSelectedMarker, Converter={StaticResource InverseBool}}"/>

                        </StackPanel>

                    </Border>


                    <DataGrid ItemsSource="{Binding Markers}"
                              SelectedItem="{Binding SelectedMarker}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding id}"
                                                Width="50"/>

                            <DataGridTextColumn Header="Típus"
                                                Binding="{Binding marker_type}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Pont"
                                                Binding="{Binding score}"
                                                Width="60"/>

                            <DataGridTextColumn Header="Lat"
                                                Binding="{Binding lat}"
                                                Width="95"/>

                            <DataGridTextColumn Header="Lng"
                                                Binding="{Binding lng}"
                                                Width="95"/>

                            <DataGridTextColumn Header="Létrehozva"
                                                Binding="{Binding created_at, Converter={StaticResource IsoDate}}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </DockPanel>

            </TabItem>
            <TabItem Header="🤝 Barátok">

                <DockPanel>

                    <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource ToolbarBackground}"
                Padding="8,6"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="0,1,0,0">

                        <StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding HasSelectedFriend, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="🔄  Státusz váltás"
                                        Padding="10,5" Margin="0,0,8,0"
                                        Background="#2980b9" Foreground="White"
                                        Command="{Binding ToggleFriendCommand}"/>
                                <Button Content="✕  Törlés"
                                        Padding="10,5"
                                        Background="#e74c3c" Foreground="White"
                                        Command="{Binding DeleteFriendCommand}"/>
                            </StackPanel>

                            <TextBlock Text="Jelölj ki egy barátot a kezeléshez."
                                       Foreground="{DynamicResource MutedText}"
                                       FontStyle="Italic" FontSize="12"
                                       Visibility="{Binding HasSelectedFriend, Converter={StaticResource InverseBool}}"/>

                        </StackPanel>

                    </Border>

                    <DataGrid ItemsSource="{Binding Friends}"
                  SelectedItem="{Binding SelectedFriend}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID"
                                    Binding="{Binding id}"
                                    Width="50"/>

                            <DataGridTextColumn Header="Küldő ID"
                                    Binding="{Binding sender_id}"
                                    Width="85"/>

                            <DataGridTextColumn Header="Fogadó ID"
                                    Binding="{Binding receiver_id}"
                                    Width="85"/>

                            <DataGridTextColumn Header="Állapot"
                                    Binding="{Binding status}"
                                    Width="85"/>

                            <DataGridTextColumn Header="Létrehozva"
                                    Binding="{Binding created_at, Converter={StaticResource IsoDate}}"
                                    Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </DockPanel>

            </TabItem>
            <TabItem Header="🛡 Klánok">

                <DataGrid ItemsSource="{Binding Clans}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              HeadersVisibility="Column">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Clán ID"
                                Binding="{Binding clan_id}"
                                Width="75"/>

                        <DataGridTextColumn Header="Clán neve"
                                Binding="{Binding clan_name}"
                                Width="160"/>

                        <DataGridTextColumn Header="Csatlakozott"
                                Binding="{Binding joined_at, Converter={StaticResource IsoDate}}"
                                Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

            </TabItem>
            


        </TabControl>

    </DockPanel>
</Window>