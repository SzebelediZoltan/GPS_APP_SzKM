<Application x:Class="gpass_app_wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:gpass_app_wpf.Converters"
             StartupUri="Views/Login.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- Itt választod ki a theme-et -->
                <ResourceDictionary Source="/Themes/Dark.xaml"/>

                <!-- Itt jönnek a control style-ok -->
                <ResourceDictionary Source="/Themes/Controls.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- Converters maradhatnak itt -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:IsoDateConverter x:Key="IsoDate"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <conv:IntToVisibilityConverter x:Key="IntToVisibility"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
